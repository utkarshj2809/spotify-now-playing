# ─────────────────────────────────────────────────────────────
# Spotify Now Playing — environment variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# Your Spotify application's Client ID (32 hex characters).
# Get it from https://developer.spotify.com/dashboard
#
# When this variable is set, visitors can log in with their own
# Spotify account with a single click — no manual Client ID entry.
VITE_SPOTIFY_CLIENT_ID=your_32_char_client_id_here
